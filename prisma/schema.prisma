generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NoteStatus {
  draft
  active
  archived
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())
  notes      Note[]
  aiSettings AISettings?
}

model Note {
  id          String     @id @default(uuid())
  title       String
  content     String
  editorMode  String     @default("text")
  scheduledAt DateTime?
  tags        String[]   @default([])
  pinned      Boolean    @default(false)
  status      NoteStatus @default(active)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
}

model AISettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  geminiApiKey    String?
  grokApiKey      String?

  activeProvider  String   @default("gemini")
  activeModel     String   @default("gemini-2.5-flash")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}