generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CognitiveMode {
  ANAK    
  REMAJA  
  DEWASA  
}

model User {
  id            String          @id @default(uuid())
  name          String
  email         String          @unique
  password      String
  cognitiveMode CognitiveMode   @default(REMAJA) 
  createdAt     DateTime        @default(now())
  
  topics          Topic[]
  traces          ThinkingTrace[]
  aiSettings      AISettings?
  
  // RELASI BARU: Menyimpan riwayat nilai
  exerciseResults ExerciseResult[] 
}

model Topic {
  id          String     @id @default(uuid())
  userId      String
  title       String    
  category    String?    
  description String?
  isCompleted Boolean    @default(false)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopics   Subtopic[]
  createdAt   DateTime   @default(now())
}

model Subtopic {
  id        String          @id @default(uuid())
  topicId   String
  title     String
  level     String    
  content   String          @db.Text
  topic     Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  traces    ThinkingTrace[]
  exercises Exercise[]

  // RELASI BARU: Menyimpan riwayat nilai
  exerciseResults ExerciseResult[]
}

model ThinkingTrace {
  id             String   @id @default(uuid())
  userId         String
  subtopicId     String
  inputMethod    String    
  stepData       Json     
  misconceptions Json?    
  status         String    
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic       Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Exercise {
  id          String   @id @default(uuid())
  subtopicId  String
  type        String
  concept     String?
  cognitiveLevel  String?
  question    String   @db.Text
  answer      String   @db.Text
  explanation String   @db.Text
  createdAt   DateTime @default(now())

  subtopic    Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
}

// =========================================================================
// MODEL BARU: Menyimpan Skor, Jawaban User, dan Analisis Kesalahan ke DB
// =========================================================================
model ExerciseResult {
  id               String   @id @default(uuid())
  userId           String
  subtopicId       String
  score            Int      // Persentase Nilai Akhir
  userAnswers      Json     // Array string jawaban user
  detailedAnalysis Json     // Array status benar/salah per soal untuk rekomendasi
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic         Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  // Memastikan 1 user hanya punya 1 riwayat aktif per sub-bab (bisa di-replace jika ulangi ujian)
  @@unique([userId, subtopicId]) 
}

model AISettings {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey      String?
  activeModel String   @default("gemini-3.1-flash-lite")
  updatedAt   DateTime @updatedAt
}