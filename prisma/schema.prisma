generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CognitiveMode {
  FAST
  BALANCED
  TEACHER
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  password         String
  cognitiveMode    CognitiveMode    @default(BALANCED)
  createdAt        DateTime         @default(now())
  
  topics           Topic[]
  traces           ThinkingTrace[]
  aiSettings       AISettings?
  exerciseResults  ExerciseResult[] 
  
  // RELASI BARU: Menyimpan Micro-Cheatsheet Skenario A
  microCheatsheets MicroCheatsheet[]
}

model Topic {
  id          String     @id @default(uuid())
  userId      String
  title       String    
  category    String?
  description String?
  isCompleted Boolean    @default(false)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopics   Subtopic[]
  createdAt   DateTime   @default(now())
}

model Subtopic {
  id               String           @id @default(uuid())
  topicId          String
  title            String
  level            String    
  content          String           @db.Text
  topic            Topic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  traces           ThinkingTrace[]
  exercises        Exercise[]
  exerciseResults  ExerciseResult[]

  // RELASI BARU: Menyimpan Micro-Cheatsheet Skenario A
  microCheatsheets MicroCheatsheet[]
}

model ThinkingTrace {
  id             String   @id @default(uuid())
  userId         String
  subtopicId     String
  inputMethod    String    
  stepData       Json     
  misconceptions Json?
  status         String    
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic       Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Exercise {
  id             String   @id @default(uuid())
  subtopicId     String
  type           String
  concept        String?
  cognitiveLevel String?
  question       String   @db.Text
  answer         String   @db.Text
  explanation    String   @db.Text
  createdAt      DateTime @default(now())

  subtopic       Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
}

model ExerciseResult {
  id               String   @id @default(uuid())
  userId           String
  subtopicId       String
  score            Int      
  userAnswers      Json     
  detailedAnalysis Json     
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic         Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  @@unique([userId, subtopicId]) 
}

model AISettings {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey      String?
  activeModel String   @default("llama3-8b-8192") // Disesuaikan menggunakan Groq Llama-3
  updatedAt   DateTime @updatedAt
}

// =========================================================================
// MODEL BARU: Menyimpan Catatan Personal AI (Hadiah Skenario A)
// =========================================================================
model MicroCheatsheet {
  id         String   @id @default(uuid())
  userId     String
  subtopicId String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtopic   Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)

  // Memastikan user hanya punya 1 rangkuman per sub-bab yang diupdate
  @@unique([userId, subtopicId])
}